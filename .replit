modules = ["nodejs-20", "python-3.12", "web"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
MONGO_URL = "mongodb://localhost:27017"
DB_NAME = "vianord"
REACT_APP_BACKEND_URL = ""
PORT = "5000"
HOST = "0.0.0.0"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash start.sh"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3001

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "mkdir -p /tmp/mongodb/data && /nix/store/3z9iq2gr9ddb0ncmxjlv81ngn6b4nm70-mongodb-6.0.5/bin/mongod --dbpath /tmp/mongodb/data --fork --logpath /tmp/mongodb/mongod.log --bind_ip 127.0.0.1 --port 27017 && cd /home/runner/workspace/backend && uvicorn server:app --host 0.0.0.0 --port 8001 &amp; cd /home/runner/workspace/frontend &amp;&amp; npx serve -s build -l 5000"]
build = ["bash", "-c", "cd /home/runner/workspace/frontend && yarn build"]
